# Microsoft Entra ID - App Registration
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-registration-client-id

# Required only for AUTH_MODE=oauth.
# In production, load this from Azure Key Vault or another secret manager.
AZURE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Authentication mode
#   jwt   -> client sends a Bearer token from Entra ID
#   oauth -> FastMCP acts as an OAuth proxy for interactive clients
# ---------------------------------------------------------------------------
AUTH_MODE=jwt

# Public URL of the server used by OAuth discovery
MCP_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# OAuth production state
# Required only when AUTH_MODE=oauth.
# Use a stable secret for FastMCP-issued JWTs.
FASTMCP_JWT_SIGNING_KEY=

# Persistent directory or mounted volume for OAuth client state.
# Use a durable path in production.
MCP_OAUTH_STORAGE_DIR=

# Fernet key used to encrypt stored OAuth tokens at rest.
MCP_OAUTH_STORAGE_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Operational settings
# ---------------------------------------------------------------------------
# Read X-Forwarded-For only behind a trusted proxy.
TRUST_PROXY_HEADERS=false

# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Uvicorn bind
MCP_HOST=0.0.0.0
MCP_PORT=8000
