AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_CLIENT_SECRET=your-client-secret  # obrigatório apenas para AUTH_MODE=oauth
AZURE_TENANT_ID=your-tenant-id
MCP_BASE_URL=http://localhost:8000

# Modo de autenticação: jwt (padrão) | oauth
# jwt   → cliente fornece Bearer token diretamente (portais, CLI, ACA)
# oauth → FastMCP faz proxy do login Azure (Claude Desktop, Cursor)
AUTH_MODE=jwt
