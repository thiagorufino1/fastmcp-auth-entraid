# ---------------------------------------------------------------------------
# Microsoft Entra ID — App Registration
# ---------------------------------------------------------------------------
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-registration-client-id

# Obrigatório apenas para AUTH_MODE=oauth.
# Em produção, leia do Azure Key Vault via Managed Identity.
AZURE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Modo de autenticação
#   jwt   → cliente envia Bearer token Entra ID (default)
#   oauth → FastMCP atua como OAuth Proxy (Claude Desktop, Cursor, VS Code)
# ---------------------------------------------------------------------------
AUTH_MODE=jwt

# ---------------------------------------------------------------------------
# URL pública do servidor (usada na descoberta OAuth)
# ---------------------------------------------------------------------------
MCP_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Operacional (opcional)
# ---------------------------------------------------------------------------
# Lê X-Forwarded-For. Habilite apenas atrás de ingress confiável.
TRUST_PROXY_HEADERS=false

# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Bind do uvicorn
MCP_HOST=0.0.0.0
MCP_PORT=8000
